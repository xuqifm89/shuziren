{
  "name": "@shuziren/desktop-app",
  "productName": "拾光引擎",
  "version": "1.0.0",
  "description": "拾光引擎桌面客户端 - Electron + Vue3 (支持离线)",
  "main": "electron/main.js",
  "author": "ShuZiRen Team",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "vite",
    "rebuild:backend": "cd ../backend && npx @electron/rebuild -m . -v 28.3.3 -w sqlite3",
    "electron:build": "vite build && electron-builder",
    "dist": "npm run build && electron-builder --win --mac --linux",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run rebuild:backend && npm run build && electron-builder --mac",
    "dist:linux": "npm run rebuild:backend && npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@shuziren/shared-components": "*",
    "axios": "^1.6.5",
    "electron-updater": "^6.3.9",
    "element-plus": "^2.5.1",
    "vue": "^3.4.21",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@vitejs/plugin-vue": "^5.0.4",
    "electron": "28.3.3",
    "electron-builder": "^24.13.3",
    "vite": "^5.1.4",
    "vite-plugin-electron": "^0.28.8"
  },
  "build": {
    "appId": "com.shuziren.digital-human",
    "productName": "拾光引擎",
    "copyright": "Copyright © 2025 ShuZiRen Team",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "electron/**/*",
      "preload/**/*",
      "resources/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!assets/avatars/**",
          "!assets/dubbings/**",
          "!assets/musics/**",
          "!assets/portraits/videos/**",
          "!assets/voices/**",
          "!assets/uploads/**",
          "!assets/works/**",
          "!output/**",
          "!data/*.log",
          "!data/uploads/**",
          "!social-auto-upload/**",
          "!node_modules/sqlite3/build/Release/obj/**",
          "!node_modules/sqlite3/deps/**",
          "!node_modules/sqlite3/src/**",
          "!node_modules/.cache/**",
          "!node_modules/*/CHANGELOG.md",
          "!node_modules/*/README.md",
          "!node_modules/*/readme.md",
          "!node_modules/*/LICENSE",
          "!node_modules/*/.github/**",
          "!node_modules/*/test/**",
          "!node_modules/*/tests/**",
          "!node_modules/*/docs/**",
          "!node_modules/*/__tests__/**"
        ]
      },
      {
        "from": "build/win-node/node.exe",
        "to": "node.exe",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asarUnpack": [
      "dist-electron/**/*",
      "electron/**/*",
      "preload/**/*"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSDocumentsFolderUsageDescription": "拾光引擎需要访问文档目录以管理媒体文件",
        "NSDownloadsFolderUsageDescription": "拾光引擎需要访问下载目录以导入媒体文件",
        "NSMicrophoneUsageDescription": "拾光引擎需要使用麦克风录制音频"
      }
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "拾光引擎",
      "uninstallDisplayName": "拾光引擎 ${version}",
      "installerLanguages": [
        "zh_CN",
        "en_US"
      ],
      "language": "2052",
      "include": "installer.nsh",
      "warningsAsErrors": false,
      "perMachine": false,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}"
    },
    "publish": {
      "provider": "generic",
      "url": "https://update.shuziren.com/desktop"
    },
    "compression": "maximum",
    "removePackageScripts": true,
    "fileAssociations": [
      {
        "ext": "szt",
        "name": "拾光引擎项目文件",
        "role": "Editor"
      }
    ]
  }
}
