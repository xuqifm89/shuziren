# ============================================
# 拾光引擎 - 环境变量配置模板
# ============================================
# 复制此文件为 .env 并填入实际值：
#   cp .env.example .env
# ============================================

# -------------------------------------------
# 通用配置
# -------------------------------------------
NODE_ENV=development

# 后端服务端口
PORT=3001

# 日志级别: debug | info | warn | error
LOG_LEVEL=info

# 允许的跨域来源（逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# -------------------------------------------
# 数据库配置
# -------------------------------------------

# 数据库类型: sqlite | postgres | mysql
DB_DIALECT=sqlite

# SQLite配置（开发环境使用）
DB_PATH=./data/database.sqlite

# PostgreSQL配置（生产环境使用）
DB_HOST=localhost
DB_PORT=5432
DB_NAME=shuziren
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# -------------------------------------------
# 文件存储配置
# -------------------------------------------

# 存储模式: local | cloud | hybrid
STORAGE_MODE=local

# 本地存储路径
LOCAL_MEDIA_PATH=./assets

# 最大本地文件大小（字节），默认10MB
MAX_LOCAL_FILE_SIZE=10485760

# -------------------------------------------
# 云存储配置（当STORAGE_MODE=cloud或hybrid时启用）
# -------------------------------------------

# 云服务商: aliyun | tencent | aws | minio
OSS_PROVIDER=aliyun

# 阿里云OSS配置
OSS_BUCKET=your-bucket-name
OSS_REGION=oss-cn-hangzhou
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret
OSS_CDN_DOMAIN=https://cdn.yourdomain.com
OSS_ENDPOINT=

# OSS路径前缀
OSS_PATH_AUDIO=audio/
OSS_PATH_VIDEO=video/
OSS_PATH_IMAGE=image/
OSS_PATH_DOCUMENT=document/

# OSS超时时间（毫秒）
OSS_TIMEOUT=30000

# OSS最大文件大小（字节），默认100MB
OSS_MAX_FILE_SIZE=104857600

# -------------------------------------------
# MinIO配置（自建对象存储）
# -------------------------------------------
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# -------------------------------------------
# JWT认证配置
# -------------------------------------------

# 用户Token密钥（必须修改为随机字符串！）
JWT_SECRET=change_this_to_a_random_string_at_least_32_characters_long_2024!

# Token过期时间（支持格式: 7d, 24h, 3600s）
JWT_EXPIRES_IN=7d

# 管理员Token密钥（必须与JWT_SECRET不同！）
ADMIN_JWT_SECRET=change_this_to_another_random_string_for_admin_tokens_2024!

# 管理员Token过期时间
ADMIN_JWT_EXPIRES_IN=24h

# 密码加密盐值轮数
PASSWORD_SALT_ROUNDS=10

# 密码长度限制
PASSWORD_MIN_LENGTH=6
PASSWORD_MAX_LENGTH=128

# -------------------------------------------
# Redis配置（可选）
# -------------------------------------------
REDIS_URL=redis://localhost:6379

# -------------------------------------------
# RunningHub AI服务配置
# -------------------------------------------
RUNNINGHUB_APP_ID=your_runninghub_app_id
RUNNINGHUB_APP_SECRET=your_runninghub_app_secret

# -------------------------------------------
# SiliconFlow AI服务配置（备用）
# -------------------------------------------
SILICONFLOW_API_KEY=your_siliconflow_api_key

# -------------------------------------------
# 微信小程序配置
# -------------------------------------------

# 微信小程序 AppID（在微信公众平台获取）
WX_APPID=

# 微信小程序 AppSecret
WX_APPSECRET=

# -------------------------------------------
# Docker部署端口映射（仅用于docker-compose）
# -------------------------------------------
BACKEND_PORT=3001
FRONTEND_PORT=80
ADMIN_PORT=8080
H5_PORT=8081
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# -------------------------------------------
# 安全警告
# -------------------------------------------
# ⚠️ 生产环境必须修改以下配置项：
# 1. JWT_SECRET - 改为强随机字符串
# 2. ADMIN_JWT_SECRET - 改为另一个强随机字符串
# 3. DB_PASSWORD - 使用复杂密码
# 4. OSS_ACCESS_KEY_ID / OSS_ACCESS_KEY_SECRET - 使用实际密钥
# 5. RUNNINGHUB_APP_SECRET - 保护好API密钥
