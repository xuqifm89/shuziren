# ==========================================
# 拾光引擎 - 生产环境配置 (Ubuntu 22.04 + Docker 26)
# ==========================================

# Docker 镜像仓库（如 Docker Hub 用户名或私有仓库地址）
DOCKER_REGISTRY=your-docker-username

# -------------------------------------------
# 数据库配置
# -------------------------------------------
DB_DIALECT=sqlite
DB_HOST=postgres
DB_NAME=shuziren
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_strong_password_here
DB_PORT=5432
DB_SSL=false

# -------------------------------------------
# 后端配置
# -------------------------------------------
BACKEND_PORT=3001
JWT_SECRET=CHANGE_ME_random_jwt_secret_key_at_least_32_chars
ADMIN_JWT_SECRET=CHANGE_ME_random_admin_jwt_secret_key_at_least_32_chars
CONFIG_ENCRYPTION_KEY=CHANGE_ME_config_encryption_key_here

# -------------------------------------------
# CORS 允许的域名（逗号分隔）
# -------------------------------------------
CORS_ORIGINS=http://your-server-ip,http://your-server-ip:8080,http://your-server-ip:8081

# -------------------------------------------
# 微信小程序配置
# -------------------------------------------
WX_APPID=
WX_APPSECRET=

# -------------------------------------------
# 端口映射
# -------------------------------------------
FRONTEND_PORT=80
ADMIN_PORT=8080
H5_PORT=8081

# -------------------------------------------
# MinIO 配置（可选）
# -------------------------------------------
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME_minio_secret_key_here

# -------------------------------------------
# Node 环境
# -------------------------------------------
NODE_ENV=production
LOG_LEVEL=info
STORAGE_MODE=local
