# ==========================================
# 拾光引擎 - 生产环境配置
# ==========================================

# Docker 镜像仓库（如 Docker Hub 用户名或私有仓库地址）
DOCKER_REGISTRY=your-docker-username

# -------------------------------------------
# 数据库配置
# -------------------------------------------
DB_DIALECT=sqlite
DB_HOST=postgres
DB_NAME=shuziren
DB_USER=postgres
DB_PASSWORD=shuziren_secure_password_2024
DB_PORT=5432
DB_SSL=false

# -------------------------------------------
# 后端配置
# -------------------------------------------
BACKEND_PORT=3001
JWT_SECRET=shuziren_jwt_secret_key_2024_production_version_more_than_32_chars
ADMIN_JWT_SECRET=shuziren_admin_jwt_secret_key_2024_production_version_safe

# -------------------------------------------
# CORS 允许的域名
# -------------------------------------------
CORS_ORIGINS=http://43.155.188.118,http://43.155.188.118:8080,http://43.155.188.118:8081

# -------------------------------------------
# 微信小程序配置
# -------------------------------------------
WX_APPID=
WX_APPSECRET=

# -------------------------------------------
# 端口映射
# -------------------------------------------
FRONTEND_PORT=80
ADMIN_PORT=8080
H5_PORT=8081

# -------------------------------------------
# MinIO 配置（可选）
# -------------------------------------------
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123456

# -------------------------------------------
# Node 环境
# -------------------------------------------
NODE_ENV=production
LOG_LEVEL=info
STORAGE_MODE=local
