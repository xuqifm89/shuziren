# ==========================================
# 拾光引擎 - 生产环境配置
# ==========================================

# Docker 镜像仓库（如 Docker Hub 用户名或私有仓库地址）
DOCKER_REGISTRY=your-docker-username

# -------------------------------------------
# 数据库配置
# -------------------------------------------
DB_DIALECT=postgres
DB_HOST=postgres
DB_NAME=digital_human
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_PORT=5432
DB_SSL=false

# -------------------------------------------
# 后端配置
# -------------------------------------------
BACKEND_PORT=3001
JWT_SECRET=CHANGE_ME_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS

# -------------------------------------------
# CORS 允许的域名
# -------------------------------------------
CORS_ORIGINS=https://your-domain.com,https://admin.your-domain.com,https://m.your-domain.com,https://api.your-domain.com

# -------------------------------------------
# 微信小程序配置
# -------------------------------------------
WX_APPID=
WX_APPSECRET=

# -------------------------------------------
# 端口映射
# -------------------------------------------
FRONTEND_PORT=80
ADMIN_PORT=8080
H5_PORT=8081
